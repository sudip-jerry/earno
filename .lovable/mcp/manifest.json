{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://eoofpynwogjmgmouxoen.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "earno-mcp",
      "version": "0.1.0",
      "title": "Earn'O"
    },
    "tools": [
      {
        "name": "get_dashboard_stats",
        "title": "Get dashboard stats",
        "description": "Return summary trading statistics for the signed-in user: open positions count, realized PnL totals, and recent activity from the futures bot.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "mode": {
              "description": "Which trading mode to summarize. Defaults to paper.",
              "type": "string",
              "enum": [
                "paper",
                "live"
              ]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_recent_trades",
        "title": "List recent trades",
        "description": "List the signed-in user's most recent closed futures trades with symbol, side, PnL, and exit reason.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Maximum number of trades to return. Defaults to 20.",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "mode": {
              "description": "Trading mode. Defaults to paper.",
              "type": "string",
              "enum": [
                "paper",
                "live"
              ]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_coin_holdings",
        "title": "Get coin holdings",
        "description": "Return the signed-in user's current open spot coin positions from the coin bot, including entry price, quantity, and unrealized cost basis.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
